{
  "expo": {
    "name": "MedInfo AI",
    "slug": "medinfo-ai",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "medinfoai",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.medinfoai.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Autoriser MedInfo AI à accéder au microphone pour transcrire vos questions vocales."
      }
    },
    "android": {
      "package": "com.medinfoai.app",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "server",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "backgroundColor": "#141E4E"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Autoriser MedInfo AI à accéder au microphone pour transcrire vos questions vocales."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
