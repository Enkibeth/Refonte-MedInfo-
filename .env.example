# Copier en .env (gitignored). Ne JAMAIS commiter les vraies valeurs.
# LLM — provider actif : anthropic (défaut) ou openai
AI_PROVIDER=anthropic
AI_MODEL_ID=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Classifieur étage 2 (deuxième lecture, 07_CLASSIFIER §3) — Gemini 2.5 Flash-Lite.
# Sans GOOGLE_GENERATIVE_AI_API_KEY, l'étage 2 reste désactivé (fail-safe ambiguous).
GOOGLE_GENERATIVE_AI_API_KEY=
# Surcharge optionnelle du modèle d'étage 2 (défaut Gemini 2.5 Flash-Lite).
CLASSIFIER_MODEL_ID=
# Embedding / rerank
VOYAGE_API_KEY=
COHERE_API_KEY=
# Supabase — projet dédié MedInfo
# EXPO_PUBLIC_* est injecté dans le bundle client (auth + RLS).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# URL publique autorisée dans Supabase Auth (Site URL/Redirect URLs).
# Recommandé en prod pour éviter que les emails de confirmation pointent vers localhost/Expo dev.
EXPO_PUBLIC_AUTH_REDIRECT_URL=
# Variables serveur Vercel/API routes. SUPABASE_URL doit pointer vers le même projet.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Vérif pro (ANS Annuaire Santé FHIR). Clé obtenue sur portail.openfhir.annuaire.sante.fr
# (catalogue → abonnement « Annuaire Santé FHIR »). Sans clé : statut pro `pending`.
ANNUAIRE_SANTE_API_KEY=
# Optionnels — overrides selon ton abonnement ANS (sinon défauts gateway v2 / en-tête ESANTE-API-KEY).
# Recherche RPPS par valeur seule par défaut (robuste v1/v2) ; ANNUAIRE_SANTE_RPPS_SYSTEM force un system FHIR.
ANNUAIRE_SANTE_API_URL=
ANNUAIRE_SANTE_API_KEY_HEADER=
ANNUAIRE_SANTE_RPPS_SYSTEM=
# Stripe (facturation web-first, ADR-0012) — secrets hors repo, à poser dans Vercel.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# price_id Stripe par plan (06_BILLING §1). Aucun plan pro (gelé ADR-0006).
STRIPE_PRICE_PUBLIC_MID=
STRIPE_PRICE_STUDENT_MID=
STRIPE_PRICE_STUDENT_PREMIUM=
# Base URL publique pour success_url/cancel_url Checkout (ex. https://medinfo-ai.vercel.app).
# Vide = origin de la requête.
EXPO_PUBLIC_APP_URL=
# Cron Vercel (agent éditorial hebdo du blog, ADR-0025). Vercel envoie
# `Authorization: Bearer ${CRON_SECRET}` avec chaque déclenchement cron ;
# SANS cette variable en Production, /api/cron/weekly-blog refuse le cron (401,
# fail-closed) et aucun article n'est généré le lundi. Générer : openssl rand -hex 32
CRON_SECRET=
# Email / monitoring
RESEND_API_KEY=
SENTRY_DSN=
